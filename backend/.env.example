# Database (Supabase)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# IPFS Pinata
PINATA_API_KEY="your_pinata_api_key_here"
PINATA_API_SECRET="your_pinata_api_secret_here"
PINATA_JWT_SECRET="your_pinata_jwt_secret_here"

# Blockchain RPC (Alchemy)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key_here"

# Authentication
# Generate a random string for secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your_secure_random_jwt_secret"
SERVER_PORT=8000

# Deployed contract address
FACTORY_ADDRESS=0x00